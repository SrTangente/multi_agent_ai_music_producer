# Environment Variables for Multi-Agent AI Music Producer

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model Configuration
DEFAULT_MODEL=gpt-4
COMPOSER_MODEL=gpt-4
ARRANGER_MODEL=gpt-4

# Application Settings
DEBUG=false
LOG_LEVEL=INFO

# Output Settings
OUTPUT_DIR=./output
